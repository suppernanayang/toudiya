# 复制为 .env.local 并填入真实值，.env.local 不会被提交到 git。

# ---- 数据库 ----
# Prisma 把相对路径解析为相对于 prisma/schema.prisma，所以要写 ../data/app.db
# 才会落在项目根目录的 data/ 下。本地开发一般不需要改这个值。
DATABASE_URL="file:../data/app.db"

# ---- 模型策略 ----
# 默认供应商：deepseek 或 openai
LLM_PROVIDER=deepseek
# 备用供应商：deepseek / openai / disabled
LLM_FALLBACK_PROVIDER=openai
# 调用失败时是否自动切换到备用供应商：true / false
LLM_AUTO_FALLBACK=true

# ---- DeepSeek ----
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
