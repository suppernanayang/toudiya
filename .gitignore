# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local sqlite database
/data/

# local file storage (保留目录结构，不提交真实文件)
/storage/**/*
!/storage/**/
!/storage/**/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# 开发时预览脚本生成的样例 PDF，不需要进 git
/scripts/*.pdf

# 浏览器插件子项目（extension/）自己的依赖不用进 git；
# dist 反而要提交——这个项目没有 CI/构建流水线，/extension 设置页的
# "下载插件安装包"是直接读这份构建产物打包给用户下载的，不提交的话
# 换一台机器/重新 clone 之后这个下载按钮就会失效。
/extension/node_modules
